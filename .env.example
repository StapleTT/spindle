# Server
PORT=3000
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars
ENCRYPTION_KEY=64_char_hex_string_for_aes256_gcm_eg_run_openssl_rand_hex_32

# System SMTP — used to send password recovery emails from noreply@spindle.staplett.xyz
#
# Option A: Self-hosted via local Postfix (no external service needed)
#   Install Postfix + OpenDKIM on the server, then use:
#   SYSTEM_SMTP_HOST=127.0.0.1
#   SYSTEM_SMTP_PORT=25
#   SYSTEM_SMTP_USER=   (leave blank — local Postfix doesn't authenticate)
#   SYSTEM_SMTP_PASS=   (leave blank)
#
# Option B: External relay (e.g. Resend, SendGrid, Postmark)
#   SYSTEM_SMTP_HOST=smtp.resend.com
#   SYSTEM_SMTP_PORT=587
#   SYSTEM_SMTP_USER=resend
#   SYSTEM_SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
#
# DNS records required on spindle.staplett.xyz either way:
#   PTR   reverse DNS on server IP → set in VPS control panel
#   SPF   TXT  @       "v=spf1 ip4:YOUR_SERVER_IP -all"
#   DKIM  TXT  mail._domainkey   (generated by OpenDKIM — see server setup docs)
#   DMARC TXT  _dmarc  "v=DMARC1; p=none;"
SYSTEM_SMTP_HOST=127.0.0.1
SYSTEM_SMTP_PORT=25
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASS=
SYSTEM_FROM_EMAIL=Spindle <noreply@spindle.staplett.xyz>

# App URL (used for OAuth callbacks and recovery links)
APP_URL=http://localhost:3000

# Set to 'true' ONLY if your IMAP/SMTP server uses a self-signed TLS certificate.
# Leaving this unset (default) enforces certificate validation on all connections.
# ALLOW_SELF_SIGNED_TLS=true

# Gmail OAuth (Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Callback: APP_URL/api/oauth/gmail/callback

# Outlook OAuth (Azure App Registration)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
# Callback: APP_URL/api/oauth/outlook/callback
