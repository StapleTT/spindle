{
  "name": "spindle",
  "version": "1.0.0",
  "description": "Centralized self-hosted email client",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "imap-simple": "^5.1.0",
    "isomorphic-dompurify": "^2.25.0",
    "mailparser": "^3.7.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src/"
    ],
    "ext": "js,json",
    "ignore": [
      "data/",
      "public/",
      "node_modules/"
    ]
  }
}
